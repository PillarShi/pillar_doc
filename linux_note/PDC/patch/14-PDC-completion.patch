diff --git a/completion_test/Makefile b/completion_test/Makefile
new file mode 100644
index 000000000..3510a48c9
--- /dev/null
+++ b/completion_test/Makefile
@@ -0,0 +1,12 @@
+CROSS_ARCH := riscv
+CROSS_COMPILE_PREFIX := ~/project/PDC/riscv64-wangzai-linux-gnu-gcc/bin/riscv64-unknown-linux-gnu-
+CUR_DIR := $(shell pwd)
+KERNEL_DIR := ~/project/PDC/linux-5.4
+
+obj-m := completion_test.o
+
+.PHONY: all clean
+all:
+	make ARCH=$(CROSS_ARCH) CROSS_COMPILE=$(CROSS_COMPILE_PREFIX) M=$(CUR_DIR) -C $(KERNEL_DIR) modules
+clean:
+	make ARCH=$(CROSS_ARCH) CROSS_COMPILE=$(CROSS_COMPILE_PREFIX) M=$(CUR_DIR) -C $(KERNEL_DIR) clean
diff --git a/completion_test/completion_test.c b/completion_test/completion_test.c
new file mode 100644
index 000000000..4700c65b7
--- /dev/null
+++ b/completion_test/completion_test.c
@@ -0,0 +1,67 @@
+// SPDX-License-Identifier: GPL-2.0
+/**
+ * My code for linux completion.
+ *
+ * Copyright (C) 2026 Pillar
+ *
+ * This module serves no practical purpose and is solely for testing purposes.
+ */
+#include <linux/kernel.h>
+#include <linux/types.h>
+#include <linux/module.h>
+#include <linux/kthread.h>
+#include <linux/completion.h>
+#include <linux/delay.h>
+
+DECLARE_COMPLETION(com);
+
+static int thread0_entry(void *data)
+{
+	pr_info("%s\n", __func__);
+	if (completion_done(&com) == false) {
+		pr_info("thread0 wait for completion\n");
+		wait_for_completion(&com);
+		pr_info("thread0 wake up\n");
+	} else {
+		pr_info("completion done\n");
+	}
+
+	return 0;
+}
+
+static int thread1_entry(void *data)
+{
+	pr_info("%s\n", __func__);
+	pr_info("thread1 wait for completion\n");
+	wait_for_completion(&com);
+	pr_info("thread1 wake up\n");
+
+	return 0;
+}
+
+static int __init completion_test_init(void)
+{
+	struct task_struct *thread0 = kthread_run(thread0_entry, NULL, "thread0");
+	struct task_struct *thread1 = kthread_run(thread1_entry, NULL, "thread1");
+
+	msleep(1000);
+	pr_info("complete all\n");
+	complete_all(&com);
+
+	kthread_stop(thread0);
+	kthread_stop(thread1);
+
+	return 0;
+}
+
+static void __exit completion_test_exit(void)
+{
+	pr_info("exit completion test\n");
+}
+
+MODULE_AUTHOR("Pillar Shi");
+MODULE_LICENSE("GPL v2");
+MODULE_DESCRIPTION("This is my completion code");
+
+module_init(completion_test_init);
+module_exit(completion_test_exit);
