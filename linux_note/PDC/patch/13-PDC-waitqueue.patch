diff --git a/waitqueue_test/waitqueue_test.c b/waitqueue_test/waitqueue_test.c
new file mode 100644
index 000000000..dc7fbc047
--- /dev/null
+++ b/waitqueue_test/waitqueue_test.c
@@ -0,0 +1,73 @@
+// SPDX-License-Identifier: GPL-2.0
+/**
+ * My code for linux waitqueue.
+ *
+ * Copyright (C) 2026 Pillar
+ *
+ * This module serves no practical purpose and is solely for testing purposes.
+ */
+#include <linux/kernel.h>
+#include <linux/types.h>
+#include <linux/module.h>
+#include <linux/kthread.h>
+#include <linux/wait.h>
+#include <linux/delay.h>
+
+static struct wait_queue_head wq;
+static int flag;
+
+static int thread0_entry(void *data)
+{
+	pr_info("thread0 wait\n");
+	wait_event_interruptible(wq, flag == 1);
+	pr_info("thread0 wake up\n");
+
+	return 0;
+}
+
+static int thread1_entry(void *data)
+{
+	pr_info("thread1 wait\n");
+	/* 虽然 普通wait 和 interruptible wait 可以一起在一个队列，但不建议 */
+	wait_event(wq, flag == 2);
+	pr_info("thread1 wake up\n");
+
+	return 0;
+}
+
+static int __init waitqueue_test_init(void)
+{
+	struct task_struct *thread0;
+	struct task_struct *thread1;
+
+	init_waitqueue_head(&wq);
+
+	thread0 = kthread_run(thread0_entry, NULL, "thread0");
+	thread1 = kthread_run(thread1_entry, NULL, "thread1");
+	flag = 0;
+
+	msleep(500);
+	pr_info("set flag = 1 and try to wake up\n");
+	flag = 1;
+	wake_up_all(&wq);
+
+	msleep(500);
+	pr_info("set flag = 2 and try to wake up\n");
+	flag = 2;
+	wake_up_all(&wq);
+
+	kthread_stop(thread0);
+	kthread_stop(thread1);
+
+	return 0;
+}
+
+static void __exit waitqueue_test_exit(void)
+{
+	pr_info("exit waitqueue test\n");
+}
+
+MODULE_AUTHOR("Pillar Shi");
+MODULE_LICENSE("GPL v2");
+MODULE_DESCRIPTION("This is my waitqueue code");
+
+module_init(waitqueue_test_init);
+module_exit(waitqueue_test_exit);
