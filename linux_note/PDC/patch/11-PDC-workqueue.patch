diff --git a/workqueue_test/workqueue_test.c b/workqueue_test/workqueue_test.c
new file mode 100644
index 000000000..0d06c311e
--- /dev/null
+++ b/workqueue_test/workqueue_test.c
@@ -0,0 +1,78 @@
+// SPDX-License-Identifier: GPL-2.0
+/**
+ * My code for linux workqueue.
+ *
+ * Copyright (C) 2026 Pillar
+ *
+ * This module serves no practical purpose and is solely for testing purposes.
+ */
+#include <linux/kernel.h>
+#include <linux/types.h>
+#include <linux/module.h>
+#include <linux/workqueue.h>
+#include <linux/delay.h>
+
+static struct workqueue_struct *wq;
+static struct work_struct job1;
+static struct work_struct job2;
+static struct work_struct job3;
+static struct delayed_work job4; /* delay work */
+
+static void job1_func(struct work_struct *work)
+{
+	pr_info("job1\n");
+	mdelay(1000);
+}
+
+static void job2_func(struct work_struct *work)
+{
+	flush_work(&job1); /* wait for job1 to complete */
+	pr_info("job2\n");
+}
+
+static void job3_func(struct work_struct *work)
+{
+	pr_info("job3\n");
+}
+
+static void job4_func(struct work_struct *work)
+{
+	pr_info("job4\n");
+}
+
+static int __init workqueue_test_init(void)
+{
+	wq = create_workqueue("my_test_wq"); /* precpu single thread work queue */
+
+	INIT_WORK(&job1, job1_func);
+	INIT_WORK(&job2, job2_func);
+	INIT_WORK(&job3, job3_func);
+	INIT_DELAYED_WORK(&job4, job4_func);
+
+	queue_work(wq, &job1);
+	queue_work(wq, &job2);
+	msleep(500);
+	pr_info("job1 and job2 500ms\n");
+
+	flush_workqueue(wq); /* wait for wq to complete */
+	queue_work(wq, &job3);
+
+	queue_delayed_work(wq, &job4, msecs_to_jiffies(1000)); /* 1000ms */
+	msleep(500);
+	pr_info("job4 500ms\n");
+
+	return 0;
+}
+
+static void __exit workqueue_test_exit(void)
+{
+	destroy_workqueue(wq);
+	pr_info("workqueue test exit\n");
+}
+
+MODULE_AUTHOR("Pillar Shi");
+MODULE_LICENSE("GPL v2");
+MODULE_DESCRIPTION("This is my workqueue code");
+
+module_init(workqueue_test_init);
+module_exit(workqueue_test_exit);
